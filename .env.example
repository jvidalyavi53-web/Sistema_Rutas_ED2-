# ---------------------------------------------------------------------------
# Variables de entorno del Sistema de Rutas
# ---------------------------------------------------------------------------
# Copia este archivo como `.env` (que NO se versiona) y rellena tu clave.
#   PowerShell:  Copy-Item .env.example .env
#
# La clave de MapTiler se obtiene gratis en https://cloud.maptiler.com/account/keys/
# IMPORTANTE: en el panel de MapTiler restringe la clave por dominio
# (Allowed origins) para que no pueda usarse desde otros sitios.
# ---------------------------------------------------------------------------

MAPTILER_API_KEY=

# Estilo del mapa (opcional): streets-v2, basic-v2, topo-v2, hybrid, ...
MAP_STYLE=streets-v2

# Vista inicial (opcional): centro de Bolivia y zoom.
MAP_CENTER_LON=-64.9
MAP_CENTER_LAT=-16.9
MAP_ZOOM=4.6

# ---------------------------------------------------------------------------
# Enrutamiento vial (opcional): traza las carreteras siguiendo vias reales.
# Usa OSRM (sin clave). La API de routing de MapTiler esta en beta cerrada.
# Pon ROUTING_HABILITADO=false para trazar lineas rectas (sin llamadas de red).
# ---------------------------------------------------------------------------
ROUTING_HABILITADO=true
OSRM_URL=https://router.project-osrm.org
ROUTING_PERFIL=driving
ROUTING_TIMEOUT=8

# Clave de sesion de Flask (opcional en desarrollo).
# SECRET_KEY=cambia-esto-en-produccion
